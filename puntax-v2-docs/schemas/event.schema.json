{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://puntax.local/schemas/event.schema.json",
  "title": "PUNTAX Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "sessionId",
    "ts",
    "kind",
    "projectDir",
    "outcome"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^evt_[A-Za-z0-9_-]+$"
    },
    "sessionId": {
      "type": "string"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "kind": {
      "type": "string",
      "enum": [
        "tool_call",
        "read",
        "edit",
        "write",
        "test",
        "lint",
        "diagnostic",
        "error",
        "permission",
        "decision",
        "memory",
        "checkpoint",
        "index"
      ]
    },
    "tool": {
      "type": [
        "string",
        "null"
      ]
    },
    "projectDir": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "symbols": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "command": {
      "type": [
        "string",
        "null"
      ]
    },
    "outcome": {
      "type": "string",
      "enum": [
        "ok",
        "error",
        "denied",
        "asked",
        "escalated",
        "skipped",
        "verified"
      ]
    },
    "summary": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 2000
    },
    "risk": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "low",
        "medium",
        "high",
        "critical",
        null
      ]
    },
    "evidence": {
      "type": "object",
      "additionalProperties": true
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
