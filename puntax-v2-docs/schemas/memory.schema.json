{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://puntax.local/schemas/memory.schema.json",
  "title": "PUNTAX Typed Memory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "projectId",
    "kind",
    "scope",
    "text",
    "severity",
    "confidence",
    "provenance",
    "createdAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^mem_[A-Za-z0-9_-]+$"
    },
    "projectId": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "decision",
        "gotcha",
        "convention",
        "api_contract",
        "test_command",
        "failure_pattern",
        "user_preference",
        "project_fact",
        "permission_rule_candidate"
      ]
    },
    "scope": {
      "type": "string",
      "enum": [
        "global",
        "project",
        "repo",
        "file",
        "symbol"
      ]
    },
    "text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "files": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "symbols": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "observed",
        "user_confirmed",
        "inferred",
        "llm_distilled",
        "imported"
      ]
    },
    "provenance": {
      "type": "object",
      "required": [
        "source"
      ],
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "user",
            "event",
            "test_failure",
            "diagnostic",
            "source",
            "llm",
            "migration",
            "manual"
          ]
        },
        "eventIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sourcePath": {
          "type": [
            "string",
            "null"
          ]
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "superseded",
        "expired",
        "rejected"
      ],
      "default": "active"
    }
  }
}
