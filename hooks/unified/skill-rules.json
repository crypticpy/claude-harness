{
  "version": "1.1",
  "description": "Canonical skill activation triggers. Controls when skills automatically suggest or block actions. Only real skills with corresponding SKILL.md files or slash commands are listed here.",
  "skills": {
    "frontend-design": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Create distinctive, production-grade frontend interfaces with high design quality. Generates creative, polished code that avoids generic AI aesthetics.",
      "promptTriggers": {
        "keywords": [
          "design",
          "UI design",
          "frontend design",
          "interface design",
          "visual design",
          "aesthetic",
          "creative design",
          "polished UI",
          "distinctive interface",
          "beautiful UI",
          "modern design",
          "design system",
          "component design",
          "web design",
          "user interface",
          "visual appeal",
          "design quality"
        ],
        "intentPatterns": [
          "(design|create|build).*?(beautiful|polished|creative|distinctive|modern).*?(UI|interface|component|page)",
          "(UI|interface|frontend).*?(design|aesthetic|visual)",
          "(build|create|implement).*?(web|component|page|application).*?(design|aesthetic)",
          "design.*?(component|interface|page|application|system)",
          "(make it|create).*?(beautiful|polished|creative|distinctive|modern)",
          "(avoid|prevent).*?(generic|bland|cookie-cutter).*?(design|aesthetic)",
          "(improve|enhance|elevate).*?(design|aesthetic|visual)"
        ]
      }
    },
    "context-layer": {
      "type": "proactive",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Use impact_check before editing, semantic_lookup for exploration, brain_search for recalling patterns. Proactive context gathering.",
      "promptTriggers": {
        "keywords": [
          "edit file",
          "edit the",
          "modify file",
          "modify the",
          "change file",
          "update file",
          "refactor",
          "rename function",
          "rename class",
          "delete function",
          "remove function",
          "breaking change",
          "downstream",
          "consumers",
          "dependents",
          "who uses",
          "what calls",
          "impact check",
          "impact_check",
          "explore",
          "exploration",
          "investigate",
          "investigation",
          "understand",
          "how does",
          "how do",
          "trace",
          "follow",
          "dig into",
          "look into",
          "research",
          "analyze codebase",
          "Explore agent",
          "exploration agent"
        ],
        "intentPatterns": [
          "(edit|modify|change|update)\\s+(the\\s+)?(file|function|class|module|component)",
          "(refactor|rename|delete|remove).*?(function|class|method|variable|file)",
          "(check|find|show).*?(impact|dependents|consumers|callers)",
          "what.*?(uses|calls|depends on|imports)",
          "who.*?(uses|calls|imports)",
          "(before|safe to).*?(edit|modify|change|delete)",
          "breaking.*?(change|modification)",
          "(explore|investigate|understand|analyze).*?(code|codebase|file|function|system|architecture)",
          "(how does|how do).*?(work|function|operate)",
          "(trace|follow|dig into|look into).*?(code|flow|logic|implementation)",
          "(launch|use|invoke).*?(explore|exploration).*?agent",
          "(research|understand).*?(pattern|convention|approach)"
        ],
        "excludePatterns": ["^commit", "^git", "commit.*?change"],
        "mcpTools": [
          "impact_check",
          "semantic_lookup",
          "symbol_context",
          "what_changed",
          "brain_search"
        ],
        "proactiveHint": "Use semantic_lookup for file summaries, impact_check before edits, brain_search for recalled patterns"
      }
    },
    "evolve": {
      "type": "slash-command",
      "enforcement": "suggest",
      "priority": "medium",
      "description": "Self-evolution analysis - aggregates lessons across sessions and proposes harness improvements. Closes the feedback loop.",
      "action": "Use the /evolve slash command (type it directly), NOT the Skill tool.",
      "promptTriggers": {
        "keywords": [
          "evolve",
          "evolution",
          "self-improvement",
          "harness improvement",
          "lesson review",
          "pattern analysis",
          "optimize harness",
          "improve hooks",
          "retrospective"
        ],
        "intentPatterns": [
          "(evolve|evolution|improve).*?(harness|hooks|config)",
          "(review|analyze).*?(lessons|patterns|sessions)",
          "(retrospective|retro).*?(session|harness)",
          "what.*?(learn|improve|fix).*?(across|from).*?sessions"
        ]
      }
    },
    "freview": {
      "type": "slash-command",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Final review - spawn completeness and code review agents with ultrathink against current session. This is a slash command, not a Skill tool skill.",
      "action": "Use the /freview slash command (type it directly), NOT the Skill tool.",
      "promptTriggers": {
        "keywords": [
          "freview",
          "final review",
          "completeness check",
          "code review",
          "review session",
          "quality check",
          "review agents"
        ],
        "intentPatterns": [
          "(final|complete).*?review",
          "(spawn|run).*?(completeness|review).*?agent",
          "(check|verify).*?(completeness|quality)",
          "review.*?(session|work|implementation)"
        ]
      }
    }
  },
  "notes": {
    "enforcement_types": {
      "suggest": "Skill suggestion appears but doesn't block execution",
      "block": "Requires skill to be used before proceeding (guardrail)",
      "warn": "Shows warning but allows proceeding"
    },
    "priority_levels": {
      "high": "Important - Trigger for most matches",
      "medium": "Moderate - Trigger for clear matches",
      "low": "Optional - Trigger only for explicit matches"
    },
    "skill_types": {
      "domain": "Standard skill invoked via the Skill tool",
      "proactive": "Skill that provides proactive hints and MCP tool suggestions",
      "slash-command": "Slash command invoked directly (e.g., /freview), NOT via the Skill tool"
    },
    "skill_overview": {
      "frontend-design": "UI/UX design - triggers on design, aesthetic, polished interface requests",
      "context-layer": "PROACTIVE - triggers on file edits to suggest impact_check for finding downstream consumers before breaking changes",
      "evolve": "SLASH COMMAND - self-evolution via /evolve, aggregates lessons and proposes harness improvements",
      "freview": "SLASH COMMAND - final review via /freview, spawns completeness and code review agents"
    }
  }
}
