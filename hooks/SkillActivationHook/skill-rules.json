{
  "version": "1.0",
  "description": "Skill activation triggers for Claude Fast project. Controls when skills automatically suggest or block actions.",
  "skills": {
    "session-management": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Complete session-based development workflow for complex multi-phase implementation tasks",
      "promptTriggers": {
        "keywords": [
          "multi-step",
          "multi-phase",
          "complex task",
          "complex feature",
          "development session",
          "start session",
          "new session",
          "implementation plan",
          "phased implementation",
          "architectural change"
        ],
        "intentPatterns": [
          "multi[- ](step|phase|part).*?(task|implementation|work|feature)",
          "(start|begin|create).*?(session|development workflow)",
          "(complex|large|major).*?(feature|refactor|implementation)",
          "(plan|design).*?(implementation|architecture|system)",
          "(phased|staged).*?(rollout|implementation|development)"
        ],
        "excludePatterns": [
          "^commit",
          "^git",
          "^push",
          "simple",
          "quick",
          "small change"
        ]
      }
    },
    "sub-agent-invocation": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "critical",
      "description": "Coordination and delegation protocols for sub agent specialist assignments",
      "promptTriggers": {
        "keywords": [
          "agent",
          "agents",
          "delegate",
          "sub-agent",
          "sub-agents",
          "specialist",
          "master-orchestrator",
          "master-orc",
          "coordination",
          "parallel",
          "Task tool",
          "analyze",
          "invoke agent",
          "launch agent"
        ],
        "intentPatterns": [
          "(use|invoke|launch|call).*?(agent|sub-agent|specialist)",
          "(delegate|assign).*?(task|work)",
          "(parallel|concurrent).*?(execution|agent|task)",
          "master[- ]orchestrator",
          "(coordinate|manage).*?(specialist|agent)"
        ]
      }
    },
    "git-commits": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Git protocol with intelligent commit format",
      "promptTriggers": {
        "keywords": [
          "commit",
          "git commit",
          "commit message",
          "git protocol",
          "push",
          "git push",
          "session completion",
          "auto-commit",
          "create commit",
          "commit changes"
        ],
        "intentPatterns": [
          "(create|make|write|generate).*?commit",
          "(git|version).*?(commit|push)",
          "(session|work).*?(complete|finish|done)",
          "commit.*?(protocol|message|format)",
          "(ready to|time to).*?(commit|push)"
        ]
      }
    },
    "codebase-navigation": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Codebase structure and efficient navigation tips",
      "promptTriggers": {
        "keywords": [
          "find",
          "locate",
          "where is",
          "search",
          "codebase",
          "project structure",
          "file structure",
          "architecture",
          "explore",
          "navigation",
          "understand structure",
          "framework",
          "analyze",
          "how is organized"
        ],
        "intentPatterns": [
          "(where is|where are|find|locate).*?(file|component|function|class)",
          "(understand|explain|show).*?(structure|architecture|organization)",
          "(explore|navigate).*?(codebase|project)",
          "how.*?(organized|structured|arranged)",
          "(search for|looking for).*?(pattern|code|implementation)"
        ]
      }
    },
    "new-skills": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "medium",
      "description": "Guide for creating Claude Code skills with proper folder structure and YAML configuration",
      "promptTriggers": {
        "keywords": [
          "create skill",
          "new skill",
          "add skill",
          "skill creation",
          "skill architecture",
          "skill folder",
          "SKILL.md",
          "skill structure",
          "build skill",
          "skill system"
        ],
        "intentPatterns": [
          "(create|add|build|make).*?skill",
          "skill.*?(creation|development|architecture)",
          "(how to|guide for).*?skill",
          "understand.*?skill.*?(system|structure)"
        ]
      }
    },
    "archon": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "medium",
      "description": "Archon MCP integration for visual task management with localhost Kanban UI",
      "promptTriggers": {
        "keywords": ["archon", "Archon MCP"],
        "intentPatterns": []
      }
    },
    "browser-debugging": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Debug web apps via Chrome DevTools Protocol. Read console logs, monitor network requests, capture screenshots.",
      "promptTriggers": {
        "keywords": [
          "browser debug",
          "console logs",
          "network requests",
          "DevTools",
          "Chrome debugging",
          "browser errors",
          "client-side errors",
          "form submission",
          "browser issues",
          "frontend debugging"
        ],
        "intentPatterns": [
          "(debug|troubleshoot).*?(browser|frontend|client)",
          "(read|check|view).*?(console|logs|network)",
          "(capture|take).*?screenshot",
          "(browser|client).*?(error|issue|bug)",
          "DevTools.*?(protocol|debugging)"
        ]
      }
    },
    "crawl-cli": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "medium",
      "description": "Web crawler with auto-discovery and markdown output. Crawl websites, extract content as markdown/json/html/txt.",
      "promptTriggers": {
        "keywords": [
          "crawl",
          "crawler",
          "scrape",
          "website content",
          "extract content",
          "llms.txt",
          "sitemap",
          "fetch documentation",
          "crawl site"
        ],
        "intentPatterns": [
          "(crawl|scrape).*?(website|site|page|url)",
          "(extract|fetch).*?(content|documentation|text)",
          "(discover|find).*?(llms.txt|sitemap)",
          "website.*?(crawl|content|extraction)"
        ]
      }
    },
    "forge-development": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "critical",
      "description": "Forge project development - Rust backend and Tauri frontend. Agent orchestration, event bus, crate architecture.",
      "promptTriggers": {
        "keywords": [
          "Forge",
          "forge",
          "Rust",
          "rust",
          "Tauri",
          "tauri",
          "crate",
          "crates",
          "cargo",
          "event bus",
          "agent orchestration",
          "SQLite",
          "Prisma Rust"
        ],
        "intentPatterns": [
          "(Forge|forge).*?(project|feature|component|backend|frontend)",
          "(Rust|rust).*?(implement|build|create|fix)",
          "(Tauri|tauri).*?(command|frontend|UI)",
          "(crate|cargo).*?(add|implement|build)",
          "event.*?bus.*?(message|routing|system)"
        ]
      }
    },
    "frontend-design": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Create distinctive, production-grade frontend interfaces with high design quality. Generates creative, polished code that avoids generic AI aesthetics.",
      "promptTriggers": {
        "keywords": [
          "design",
          "UI design",
          "frontend design",
          "interface design",
          "visual design",
          "aesthetic",
          "creative design",
          "polished UI",
          "distinctive interface",
          "beautiful UI",
          "modern design",
          "design system",
          "component design",
          "web design",
          "user interface",
          "visual appeal",
          "design quality"
        ],
        "intentPatterns": [
          "(design|create|build).*?(beautiful|polished|creative|distinctive|modern).*?(UI|interface|component|page)",
          "(UI|interface|frontend).*?(design|aesthetic|visual)",
          "(build|create|implement).*?(web|component|page|application).*?(design|aesthetic)",
          "design.*?(component|interface|page|application|system)",
          "(make it|create).*?(beautiful|polished|creative|distinctive|modern)",
          "(avoid|prevent).*?(generic|bland|cookie-cutter).*?(design|aesthetic)",
          "(improve|enhance|elevate).*?(design|aesthetic|visual)"
        ]
      }
    },
    "analytics": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Analytics integration with Umami for tracking, custom events, and conversion attribution",
      "promptTriggers": {
        "keywords": [
          "analytics",
          "tracking",
          "Umami",
          "umami",
          "custom events",
          "scroll tracking",
          "click tracking",
          "goals",
          "pageviews",
          "event tracking",
          "conversion tracking"
        ],
        "intentPatterns": [
          "(add|implement|setup|configure).*?(analytics|tracking|Umami)",
          "(track|monitor).*?(events|clicks|scrolls|conversions|pageviews)",
          "Umami.*?(integration|setup|configuration)",
          "analytics.*?(implementation|setup|events)",
          "(custom|scroll|click).*?(event|tracking|goal)"
        ]
      }
    },
    "documentation-research": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "critical",
      "description": "Fetch up-to-date library documentation using Context7 API with 98% context savings",
      "promptTriggers": {
        "keywords": [
          "documentation",
          "docs",
          "API reference",
          "library docs",
          "framework docs",
          "current docs",
          "latest docs",
          "how to use",
          "Context7",
          "Context 7",
          "library documentation",
          "official docs"
        ],
        "intentPatterns": [
          "(get|fetch|find|show).*?(documentation|docs).*?(for|about|on)",
          "how (to|do I).*?(use|implement|configure).*?(library|framework|package)",
          "(current|latest|official).*?(documentation|docs|API)",
          "(look up|search).*?(documentation|docs|reference)",
          "Context7.*?(documentation|docs|library)"
        ]
      }
    },
    "infra-ops": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Comprehensive infrastructure operations: VPS management, SSH, Docker, Coolify PaaS, Nginx deployments, SSL certificates, security hardening, and cloud service setup",
      "promptTriggers": {
        "keywords": [
          "VPS",
          "server",
          "SSH",
          "deploy",
          "deployment",
          "Docker",
          "Coolify",
          "Nginx",
          "SSL",
          "firewall",
          "UFW",
          "fail2ban",
          "infrastructure",
          "DevOps",
          "security hardening",
          "AWS",
          "Lightsail",
          "S3",
          "Cloudflare",
          "DNS",
          "production server",
          "container",
          "docker-compose"
        ],
        "intentPatterns": [
          "(ssh|connect|access).*?(server|VPS|remote)",
          "(deploy|push|release).*?(app|application|site|service)",
          "(setup|configure|install).*?(Docker|Nginx|SSL|firewall|server)",
          "(secure|harden).*?(server|VPS|SSH)",
          "(manage|administer).*?(server|infrastructure|VPS)",
          "(Coolify|AWS|Lightsail|S3|Cloudflare).*?(setup|configure|deploy)",
          "(docker|container).*?(build|run|deploy|compose)"
        ]
      }
    },
    "context-layer": {
      "type": "proactive",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Use impact_check before editing, semantic_lookup for exploration, brain_search for recalling patterns. Proactive context gathering.",
      "promptTriggers": {
        "keywords": [
          "edit file",
          "edit the",
          "modify file",
          "modify the",
          "change file",
          "update file",
          "refactor",
          "rename function",
          "rename class",
          "delete function",
          "remove function",
          "breaking change",
          "downstream",
          "consumers",
          "dependents",
          "who uses",
          "what calls",
          "impact check",
          "impact_check",
          "explore",
          "exploration",
          "investigate",
          "investigation",
          "understand",
          "how does",
          "how do",
          "trace",
          "follow",
          "dig into",
          "look into",
          "research",
          "analyze codebase",
          "Explore agent",
          "exploration agent"
        ],
        "intentPatterns": [
          "(edit|modify|change|update)\\s+(the\\s+)?(file|function|class|module|component)",
          "(refactor|rename|delete|remove).*?(function|class|method|variable|file)",
          "(check|find|show).*?(impact|dependents|consumers|callers)",
          "what.*?(uses|calls|depends on|imports)",
          "who.*?(uses|calls|imports)",
          "(before|safe to).*?(edit|modify|change|delete)",
          "breaking.*?(change|modification)",
          "(explore|investigate|understand|analyze).*?(code|codebase|file|function|system|architecture)",
          "(how does|how do).*?(work|function|operate)",
          "(trace|follow|dig into|look into).*?(code|flow|logic|implementation)",
          "(launch|use|invoke).*?(explore|exploration).*?agent",
          "(research|understand).*?(pattern|convention|approach)"
        ],
        "excludePatterns": [
          "^commit",
          "^git",
          "commit.*?change"
        ],
        "mcpTools": [
          "impact_check",
          "semantic_lookup",
          "symbol_context",
          "what_changed",
          "brain_search"
        ],
        "proactiveHint": "Use semantic_lookup for file summaries, impact_check before edits, brain_search for recalled patterns"
      }
    }
  },
  "notes": {
    "enforcement_types": {
      "suggest": "Skill suggestion appears but doesn't block execution",
      "block": "Requires skill to be used before proceeding (guardrail)",
      "warn": "Shows warning but allows proceeding"
    },
    "priority_levels": {
      "critical": "Highest - Always trigger when matched (e.g., sub-agent-invocation before Task tool)",
      "high": "Important - Trigger for most matches (e.g., session-management, git-commits)",
      "medium": "Moderate - Trigger for clear matches (e.g., skill creation, framework context)",
      "low": "Optional - Trigger only for explicit matches"
    },
    "customization": {
      "keywords": "Session-based workflow, Forge/Rust, infrastructure, analytics",
      "intentPatterns": "Use regex for flexible user intent matching",
      "priority_rationale": "Critical: sub-agent, documentation, session, forge-development | High: commits, navigation, design, infra | Medium: skills, archon, crawl-cli"
    },
    "skill_overview": {
      "session-management": "Complex multi-phase work - triggers on multi-step tasks, phased implementations, architectural changes (NOT simple features/commits)",
      "sub-agent-invocation": "Critical coordination - triggers before ANY agent/Task tool usage",
      "forge-development": "Forge project - triggers on Rust, Tauri, crates, event bus, agent orchestration",
      "git-commits": "Version control - triggers on commits, pushes, session completion",
      "codebase-navigation": "Exploration - triggers on finding, searching, understanding structure",
      "new-skills": "Meta-development - triggers on skill creation and system understanding",
      "archon": "Task management - triggers when Archon MCP mentioned",
      "browser-debugging": "Frontend debugging - triggers on console logs, network requests, browser issues",
      "crawl-cli": "Web crawling - triggers on site crawling, content extraction, documentation fetching",
      "analytics": "Analytics integration - triggers on Umami, tracking, events, conversions",
      "documentation-research": "Library docs - triggers on documentation requests, Context7, API references",
      "infra-ops": "Infrastructure - triggers on VPS, SSH, Docker, deployments, server management",
      "context-layer": "PROACTIVE - triggers on file edits to suggest impact_check for finding downstream consumers before breaking changes"
    }
  }
}
