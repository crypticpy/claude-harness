{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "260000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80"
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "cf-approve permission"
          },
          {
            "type": "command",
            "command": "$HOME/.claude-deck/hooks/claude-deck-hook.sh permission \"$TOOL_NAME\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/hooks/unified/unified-hook.mjs post-edit"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/hooks/unified/unified-hook.mjs post-tool"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude-deck/hooks/claude-deck-hook.sh tool-complete"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/hooks/unified/unified-hook.mjs precompact"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude-deck/hooks/claude-deck-hook.sh tool-use \"$TOOL_NAME\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "'$HOME/Library/Application Support/tokf/hooks/pre-tool-use.sh'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/hooks/unified/unified-hook.mjs session-start"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/hooks/unified/unified-hook.mjs stop"
          },
          {
            "type": "command",
            "command": "$HOME/.claude-deck/hooks/claude-deck-hook.sh status idle"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/hooks/unified/unified-hook.mjs prompt"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/plugins/context-layer/bin/personality-hook.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude-deck/hooks/claude-deck-hook.sh prompt-submit"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": false,
    "code-review@claude-code-plugins": true,
    "frontend-design@claude-code-plugins": true,
    "github@claude-plugins-official": false,
    "gopls-lsp@claude-plugins-official": false,
    "jdtls-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": false,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "supabase@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754084298460
  }
}
